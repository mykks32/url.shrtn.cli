{
  "name": "url.shrtn.cli",
  "version": "1.0.0",
  "description": "A fast and minimal URL shortener CLI in TypeScript",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "keywords": [
    "url",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mykks32/url.shrtn.cli.git"
  },
  "license": "MIT",
  "author": "mykks32",
  "scripts": {
    "build": "pnpm -r run build",
    "dev:api": "pnpm --filter @mykks32/api run start:dev",
    "start:api": "pnpm --filter @mykks32/api run start",
    "start:cli": "pnpm --filter @mykks32/cli run start",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "dotenv": "^17.4.0"
  }
}